# =============================================
#   LeadFlow CRM - Environment Variables
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local:   mongodb://localhost:27017/leadflow_crm
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/leadflow_crm
MONGO_URI=mongodb://localhost:27017/leadflow_crm

# JWT Secrets (use long, random strings in production!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_also_change_this_in_production

# JWT Expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Frontend URL
CLIENT_URL=http://localhost:3000

# Admin seed (used by npm run seed)
SEED_ADMIN_EMAIL=admin@leadflow.com
SEED_ADMIN_PASSWORD=Admin@1234
